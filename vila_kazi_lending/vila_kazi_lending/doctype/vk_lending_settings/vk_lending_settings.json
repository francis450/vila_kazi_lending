 "fields": [
  {
   "fieldname": "loan_rules_section",
   "fieldtype": "Section Break",
   "label": "Loan Rules"
  },
  {
   "fieldname": "security_fee_percentage",
   "fieldtype": "Float",
   "label": "Security Fee (%)",
   "default": "5"
  },
  {
   "fieldname": "max_loan_to_salary_ratio",
   "fieldtype": "Float",
   "label": "Max Loan : Salary Ratio",
   "default": "0.5"
  },
  {
   "fieldname": "accrual_cap_multiplier",
   "fieldtype": "Float",
   "label": "Accrual Cap Multiplier",
   "default": "2.0"
  },
  {
   "fieldname": "collections_section",
   "fieldtype": "Section Break",
   "label": "Collections"
  },
  {
   "fieldname": "overdue_alert_day_3",
   "fieldtype": "Check",
   "label": "Alert Lender at Day 3",
   "default": "1"
  },
  {
   "fieldname": "overdue_alert_day_7",
   "fieldtype": "Check",
   "label": "Alert Lender at Day 7",
   "default": "1"
  },
  {
   "fieldname": "weekly_digest_enabled",
   "fieldtype": "Check",
   "label": "Enable Weekly Overdue Digest",
   "default": "1"
  },
  {
   "fieldname": "last_weekly_digest_sent",
   "fieldtype": "Date",
   "label": "Last Weekly Digest Sent",
   "read_only": 1
  },
  {
   "fieldname": "paybill_section",
   "fieldtype": "Section Break",
   "label": "Paybill & Repayment"
  },
  {
   "fieldname": "paybill_number",
   "fieldtype": "Data",
   "label": "Paybill Number",
   "description": "M-Pesa Paybill number used by borrowers to repay loans."
  },
  {
   "fieldname": "paybill_account_ref_prefix",
   "fieldtype": "Data",
   "label": "Paybill Account Reference",
   "description": "Default account reference instruction (e.g. 'Your registered phone number')."
  },
  {
   "fieldname": "notification_section",
   "fieldtype": "Section Break",
   "label": "Notifications"
  },
  {
   "fieldname": "lender_notification_email",
   "fieldtype": "Data",
   "label": "Lender Notification Email Override",
   "description": "If set, all internal notifications go here instead of all Lender Manager users."
  },
  {
   "fieldname": "last_overdue_digest_sent",
   "fieldtype": "Date",
   "label": "Last Overdue Digest Sent",
   "read_only": 1,
   "description": "Automatically updated by the daily scheduler. Reset manually to re-send the digest."
  },
  {
   "fieldname": "ai_scoring_section",
   "fieldtype": "Section Break",
   "label": "AI Scoring Thresholds (Phase 2)"
  },
  {
   "fieldname": "score_approve_threshold",
   "fieldtype": "Float",
   "label": "Auto-Approve Score Threshold",
   "default": "70"
  },
  {
   "fieldname": "score_review_threshold",
   "fieldtype": "Float",
   "label": "Manual Review Score Threshold",
   "default": "50"
  },
  {
   "fieldname": "gambling_income_ratio_limit",
   "fieldtype": "Float",
   "label": "Gambling : Income Limit",
   "default": "0.10"
  },
  {
   "fieldname": "competing_loan_burden_limit",
   "fieldtype": "Float",
   "label": "Competing Loan Burden Limit",
   "default": "0.30"
  },
  {
   "fieldname": "api_keys_section",
   "fieldtype": "Section Break",
   "label": "API Keys (Phase 2)"
  },
  {
   "fieldname": "llm_api_key",
   "fieldtype": "Password",
   "label": "LLM API Key"
  },
  {
   "fieldname": "africastalking_api_key",
   "fieldtype": "Password",
   "label": "Africa's Talking API Key"
  },
  {
   "fieldname": "africastalking_sender_id",
   "fieldtype": "Data",
   "label": "Africa's Talking Sender ID"
  },
  {
   "fieldname": "daraja_consumer_key",
   "fieldtype": "Password",
   "label": "Daraja Consumer Key"
  },
  {
   "fieldname": "daraja_consumer_secret",
   "fieldtype": "Password",
   "label": "Daraja Consumer Secret"
  },
  {
   "fieldname": "gambling_keywords_section",
   "fieldtype": "Section Break",
   "label": "M-Pesa Gambling Keywords"
  },
  {
   "fieldname": "gambling_keywords",
   "fieldtype": "Small Text",
   "label": "Gambling Platform Keywords (comma-separated)",
   "default": "SportPesa,Odibets,Betika,Betway,Mozzart Bet"
  }
 ],
 "permissions": [
  {
   "role": "Lender Manager",
   "read": 1,
   "write": 1
  },
  {
   "role": "System Manager",
   "read": 1,
   "write": 1
  }
 ]
